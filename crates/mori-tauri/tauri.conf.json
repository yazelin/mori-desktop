{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mori",
  "version": "0.3.2",
  "identifier": "ai.yazelin.mori",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Mori",
        "width": 960,
        "height": 940,
        "minWidth": 720,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "floating",
        "title": "Mori (floating)",
        "width": 160,
        "height": 160,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "visible": true,
        "center": true
      },
      {
        "label": "chat_bubble",
        "title": "Mori (chat)",
        "width": 360,
        "height": 56,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "shadow": false,
        "visible": false,
        "focus": false
      },
      {
        "label": "picker",
        "title": "Mori — 切換 Profile",
        "width": 520,
        "height": 280,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "visible": false,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "森林精靈 Mori 的桌面身體",
    "longDescription": "Mori 是個跨平台的 AI 管家,聽你說話、處理你的任務、記住你的偏好。"
  }
}
